# herdr-aws-ssm — local configuration template.
# Copy to `.env` (which is git-ignored) and edit for your setup:
#   cp .env.example .env
# Everything here is optional; unset values fall back to your current AWS
# context ($AWS_PROFILE / $AWS_REGION) and sensible defaults.

# Space-separated list of  env=aws-profile  pairs shown in the instance picker.
# The env label is arbitrary; any label named exactly "prod" is treated as
# production and requires a typed "yes-prod" confirmation before connecting.
# Examples:
#   HERDR_SSM_PROFILES="default=default"
#   HERDR_SSM_PROFILES="dev=my-dev-sso prod=my-prod-sso"
# HERDR_SSM_PROFILES="default=default"

# AWS region to search / connect in. Defaults to $AWS_REGION, then
# $AWS_DEFAULT_REGION, then us-east-1.
# HERDR_SSM_REGION="us-east-1"

# SSH login user. "auto" detects it from each instance's AMI
# (Ubuntu -> ubuntu, Amazon Linux -> ec2-user, Debian -> admin, ...).
# Set a fixed value to skip detection.
# HERDR_SSM_OSUSER="auto"
